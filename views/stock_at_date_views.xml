<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== Wizard: only date selection ===== -->
    <record id="view_stock_at_date_wizard_form" model="ir.ui.view">
        <field name="name">ft.advstock.stock.at.date.wizard.form</field>
        <field name="model">ft.advstock.stock.at.date.wizard</field>
        <field name="arch" type="xml">
            <form string="Inventario a la Fecha">
                <group>
                    <group>
                        <field name="date"/>
                    </group>
                </group>
                <footer>
                    <button name="action_compute" type="object"
                            string="Calcular" class="btn-primary"
                            icon="fa-calculator"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ===== Results: Tree view ===== -->
    <record id="view_stock_at_date_line_tree" model="ir.ui.view">
        <field name="name">ft.advstock.stock.at.date.line.tree</field>
        <field name="model">ft.advstock.stock.at.date.line</field>
        <field name="arch" type="xml">
            <tree string="Inventario a la Fecha" create="0" edit="0" delete="0">
                <field name="warehouse_name"/>
                <field name="location_name" string="Ubicación"/>
                <field name="product_name" string="Producto"/>
                <field name="product_categ_id" string="Categoría"
                       optional="hide"/>
                <field name="lot_name" string="Lote/Serie"/>
                <field name="quantity" sum="Total"/>
                <field name="uom_id" string="UdM"/>
                <field name="cutoff_date" string="Fecha de Corte" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ===== Results: Search view ===== -->
    <record id="view_stock_at_date_line_search" model="ir.ui.view">
        <field name="name">ft.advstock.stock.at.date.line.search</field>
        <field name="model">ft.advstock.stock.at.date.line</field>
        <field name="arch" type="xml">
            <search string="Inventario a la Fecha">
                <field name="product_name" string="Producto"/>
                <field name="location_name" string="Ubicación"/>
                <field name="warehouse_name" string="Almacén"/>
                <field name="lot_name" string="Lote"/>
                <field name="product_categ_id" string="Categoría"/>
                <separator/>
                <filter name="has_stock" string="Con Existencia"
                        domain="[('quantity', '>', 0)]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_warehouse" string="Almacén"
                            context="{'group_by': 'warehouse_name'}"/>
                    <filter name="group_location" string="Ubicación"
                            context="{'group_by': 'location_name'}"/>
                    <filter name="group_category" string="Categoría"
                            context="{'group_by': 'product_categ_id'}"/>
                    <filter name="group_product" string="Producto"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_lot" string="Lote"
                            context="{'group_by': 'lot_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ===== Wizard Action (menu entry) ===== -->
    <record id="action_stock_at_date_wizard" model="ir.actions.act_window">
        <field name="name">Inventario a la Fecha</field>
        <field name="res_model">ft.advstock.stock.at.date.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
