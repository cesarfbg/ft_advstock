<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_advanced_stock" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.advanced.stock</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="feral_tech_base.res_config_settings_view_form_feral_tech"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='feral_tech_settings_content']" position="inside">

                <h2>Inventario Avanzado</h2>

                <div class="row mt16 o_settings_container" id="advanced_stock_settings">
                    <!-- LEFT: License + Decimals -->
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <label for="ft_advstock_license_token"/>
                            <div class="text-muted">
                                Token proporcionado por Feral Tech para activar la licencia del módulo Inventario Avanzado.
                            </div>
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="ft_advstock_license_token"/>
                                </div>
                            </div>
                            <div class="mt16">
                                <div class="o_row">
                                    <field name="ft_advstock_use_decimals"/>
                                    <label for="ft_advstock_use_decimals"/>
                                </div>
                                <div class="text-muted">
                                    Mostrar valores con 2 decimales en los reportes. Si está desactivado, los números se redondean a enteros.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT: Semaphore config -->
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <i class="fa fa-flag fa-lg text-primary"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Flags de Rotación (Valores Predeterminados)</span>
                            <div class="text-muted">
                                Rangos de días de rotación para clasificar productos.
                            </div>
                            <div class="content-group mt16">
                                <div class="row">
                                    <label for="ft_advstock_flag_yellow_min" class="col-4 col-lg-4" string="Amarillo Min"/>
                                    <field name="ft_advstock_flag_yellow_min" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ft_advstock_flag_green_min" class="col-4 col-lg-4" string="Verde Min"/>
                                    <field name="ft_advstock_flag_green_min" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ft_advstock_flag_green_max" class="col-4 col-lg-4" string="Verde Max"/>
                                    <field name="ft_advstock_flag_green_max" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ft_advstock_flag_yellow_max" class="col-4 col-lg-4" string="Amarillo Max"/>
                                    <field name="ft_advstock_flag_yellow_max" class="col-2"/>
                                </div>
                            </div>
                            <div class="mt16">
                                <button name="%(ft_advstock.action_product_flag_config)d"
                                        string="Configurar Flags por Producto"
                                        type="action"
                                        class="btn-link"
                                        icon="fa-arrow-right"/>
                            </div>
                        </div>
                    </div>
                </div>

            </xpath>
        </field>
    </record>
</odoo>
