<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_advanced_stock" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.advanced.stock</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block"
                     data-string="Inventario Avanzado"
                     string="Inventario Avanzado"
                     data-key="advanced_stock_reports">

                    <div class="app_settings_header" style="background-color: #0F084B; padding: 16px;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <img src="/advanced_stock_reports/static/description/icon.png"
                                 style="max-height: 40px;" alt="Feral Tech"/>
                            <span style="color: white; font-size: 18px; font-weight: bold;">
                                Feral Tech - Inventario Avanzado
                            </span>
                        </div>
                    </div>

                    <h2>Licencia</h2>

                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="license_token"/>
                                <div class="text-muted">
                                    Token proporcionado por Feral Tech para activar la licencia del módulo Inventario Avanzado.
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="license_token"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </xpath>
        </field>
    </record>
</odoo>
