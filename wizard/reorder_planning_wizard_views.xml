<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard Form -->
    <record id="view_reorder_planning_wizard_form" model="ir.ui.view">
        <field name="name">reorder.planning.wizard.form</field>
        <field name="model">reorder.planning.wizard</field>
        <field name="arch" type="xml">
            <form string="Planeación de Reorden">
                <div class="text-center" style="padding: 40px 20px;">
                    <h2 style="color: #126899;">Planeación de Reorden</h2>
                    <p class="text-muted" style="font-size: 16px;">
                        Este reporte estará disponible próximamente.
                    </p>
                    <p class="text-muted">
                        <i class="fa fa-clock-o" style="font-size: 48px; color: #17BEBB;"/>
                    </p>
                </div>
                <footer>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_reorder_planning_wizard" model="ir.actions.act_window">
        <field name="name">Planeación (Reorder)</field>
        <field name="res_model">reorder.planning.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
